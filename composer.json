{
  "name": "ovarun/laravel-disposable-email-validation",
  "description": "Laravel package to detect disposable email addresses using disposable-email-domains list.",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "email", "validation", "disposable-email", "spam", "temporary-email"],
  "homepage": "https://github.com/ovarun/laravel-disposable-email-validation",
  "authors": [
    {
      "name": "OV",
      "email": "mail@arunov.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^11.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Ovarun\\DisposableEmail\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ovarun\\DisposableEmail\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ovarun\\DisposableEmail\\DisposableEmailServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
